# =============================================================================
# VAJRA ORCHESTRATOR CONFIGURATION
# =============================================================================
# These environment variables are referenced in WORKFLOW.md via $VAR_NAME syntax.
# Vajra resolves them at startup.
# =============================================================================

# Linear API key (required)
LINEAR_API_KEY=

# GitHub token for PR creation and API access (required)
GITHUB_TOKEN=

# GitHub webhook secret for signature verification (optional)
GITHUB_WEBHOOK_SECRET=

# Vajra API key — protects the REST API (required)
VAJRA_API_KEY=

# Vajra API server config (optional)
VAJRA_API_PORT=3847
VAJRA_API_HOST=0.0.0.0
VAJRA_CORS_ORIGIN=http://localhost:3000

# Logs directory (optional, default: ~/.vajra-runs)
VAJRA_LOGS_ROOT=

# Slack notifications (optional)
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
