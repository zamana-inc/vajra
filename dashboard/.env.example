# =============================================================================
# VAJRA DASHBOARD CONFIGURATION
# =============================================================================
# Copy this file to .env.local
# For local development, defaults work out of the box.
# =============================================================================

# Vajra API (server-side only, proxied via /api/vajra).
VAJRA_API_URL=http://localhost:3847
VAJRA_API_KEY=        # Must match the orchestrator's VAJRA_API_KEY

# Dashboard password protection
DASHBOARD_PASSWORD=changeme
